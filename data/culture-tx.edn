#:culture{:id "lbr.dish.dumboy", :name "Dumboy", :country "LBR", :kind :dish, :summary "Pounded starch preparation made from boiled cassava, one of the staple dishes of Liberian cuisine alongside fufu.", :url "https://en.wikipedia.org/wiki/Liberian_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:url "https://en.wikipedia.org/wiki/Liberian_cuisine", :id "lbr.dish.cassava-leaf", :kind :dish, :name-local "gbassajama", :country "LBR", :retrieved-at "2026-07-17", :summary "Liberian dish made from ground cassava leaves, braised and tenderized in a broth and mixed with red palm oil stock.", :name "Cassava leaf", :url-provenance :wikipedia-en}
#:culture{:id "lbr.dish.palm-butter", :name "Palm butter", :country "LBR", :kind :dish, :summary "One of the popular Liberian stews, locally referred to as 'soups', eaten with staples such as rice or fufu.", :url "https://en.wikipedia.org/wiki/Liberian_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "lbr.dish.pepper-soup", :name "Pepper soup", :country "LBR", :kind :dish, :summary "Spicy stew popular in Liberia, eaten with fufu or rice.", :url "https://en.wikipedia.org/wiki/Liberian_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "lbr.beverage.palm-wine", :name "Palm wine", :country "LBR", :kind :beverage, :summary "Traditional palm wine made from fermenting palm-tree sap is popular in Liberia, drunk as is, used as a yeast substitute in bread, or used as vinegar.", :url "https://en.wikipedia.org/wiki/Liberian_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
